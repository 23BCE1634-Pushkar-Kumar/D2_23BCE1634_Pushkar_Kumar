# API Configuration
VITE_API_URL=http://localhost:5000/api

# Third-party API Keys
VITE_OPENWEATHER_API_KEY=your-openweather-api-key-here

# Application Configuration
VITE_APP_NAME=Agri Supply Chain Platform
VITE_APP_VERSION=1.0.0

# Map Configuration
VITE_MAP_DEFAULT_ZOOM=13
VITE_MAP_DEFAULT_LAT=28.6139
VITE_MAP_DEFAULT_LNG=77.2090

# Feature Flags
VITE_ENABLE_GPS_SIMULATION=true
VITE_ENABLE_MOCK_DATA=true
VITE_ENABLE_WEATHER_WIDGET=true

# Blockchain Configuration
VITE_BLOCKCHAIN_NETWORK=hardhat
VITE_HARDHAT_RPC_URL=http://127.0.0.1:8545
VITE_CHAIN_ID=31337

# Contract Addresses (will be loaded from API)
VITE_AUCTION_CONTRACT_ADDRESS=
VITE_TRACKING_CONTRACT_ADDRESS=
VITE_PROVENANCE_CONTRACT_ADDRESS=

# QR Code Configuration
VITE_QR_SCANNER_ENABLED=true
VITE_VERIFICATION_BASE_URL=http://localhost:5173/verify

# QR Code Configuration
VITE_QR_SCANNER_DELAY=500
VITE_QR_SCANNER_ASPECT_RATIO=1

# Development Configuration
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug

# Company Information
VITE_COMPANY_NAME=AGrihub
VITE_COMPANY_EMAIL=support@agrihub.com
VITE_COMPANY_PHONE=+1-234-567-8900