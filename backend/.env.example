# Development Environment
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/agriSupplyChain

# JWT Configuration
JWT_SECRET=super-secret-jwt-key-change-this-in-production-environment

# Server Configuration
PORT=5000

# Third-party API Keys
OPENWEATHER_API_KEY=your-openweather-api-key-here

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=5242880

# Logging Level
LOG_LEVEL=info

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
HARDHAT_NETWORK=localhost

# Contract Addresses (updated automatically after deployment)
AUCTION_CONTRACT_ADDRESS=
TRACKING_CONTRACT_ADDRESS=
PROVENANCE_CONTRACT_ADDRESS=

# Email Configuration (for notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# SMS Configuration (optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number